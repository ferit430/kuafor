{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(api|backend/api)/(.*)",
      "dest": "/$1/$2.php"
    }
  ],
  "regions": ["cdg1"]
}
